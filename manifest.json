{
  "manifest_version": 3,
  "name": "PanSub - Panopto 中文字幕",
  "version": "1.1.1",
  "description": "实时翻译 Panopto 视频英文字幕为中文，叠加显示在播放器上方。",
  "permissions": ["storage"],
  "host_permissions": [
    "*://*.panopto.com/*",
    "*://*.au.panopto.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*.panopto.com/*",
        "*://*.au.panopto.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "assets/icon16.png",
    "32": "assets/icon32.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "PanSub",
    "default_icon": {
      "16": "assets/icon16.png",
      "32": "assets/icon32.png",
      "48": "assets/icon48.png",
      "128": "assets/icon128.png"
    }
  },
  "options_page": "options.html"
}
